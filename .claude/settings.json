{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run preview)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Read(//home/user/spicet-app/**)"
    ],
    "deny": [
      "Read(//home/user/spicet-app/.env)",
      "Read(//home/user/spicet-app/.env.*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f package.json ] && [ ! -d node_modules ]; then echo 'spicet-app: installing dependencies (node_modules missing)...'; npm install --no-audit --no-fund >/dev/null 2>&1 && echo 'spicet-app: dependencies ready.' || echo 'spicet-app: npm install failed — run it manually.'; fi"
          }
        ]
      }
    ]
  }
}
